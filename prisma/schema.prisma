generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique /// @encrypted
  emailHash             String?            @unique
  emailVerified         DateTime?
  fullName              String?
  isAdmin               Boolean            @default(false)
  isManager             Boolean            @default(false)
  status                PsychologistStatus @default(PENDING)
  isPublished           Boolean            @default(false)
  slug                  String?            @unique
  gender                String?
  birthDate             DateTime?
  city                  String?
  workFormat            String?
  mainParadigm          String[]
  certificationLevel    Int                @default(0)
  firstDiplomaDate      DateTime?
  lastCertificationDate DateTime?
  shortBio              String?            @db.VarChar(400)
  longBio               String?
  price                 Int?
  contactInfo           String?            @db.VarChar(150)
  unsubscribed          Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  draftData             Json?              @default("{}") @db.Json
  hasUnpublishedChanges Boolean            @default(false)
  avatarUrl             String?
  freeSession           Int                @default(0)
  moderatedArticles     Article[]          @relation("ModeratedArticles")
  articles              Article[]          @relation("AuthorArticles")
  articleCredits        ArticleCredit[]
  documents             Document[]         @relation("user_documents")
  verifiedDocuments     Document[]         @relation("verifier_documents")
  moderatorRecords      ModerationRecord[] @relation("moderator_records")
  moderationRecords     ModerationRecord[] @relation("moderated_user")
  sessions              Session[]
  dialogs               Dialog[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]

  @@index([email])
  @@index([status])
  @@index([isPublished])
  @@index([city])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model Article {
  id               String           @id @default(cuid())
  title            String
  content          String
  excerpt          String?
  slug             String           @unique
  image            String?
  isPublished      Boolean          @default(false)
  publishedAt      DateTime?
  userId           String?
  moderatedAt      DateTime?
  moderatedBy      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tags             String[]         @default([])
  moderatorComment String?
  submittedAt      DateTime?
  moderationStatus ModerationStatus @default(DRAFT)
  moderator        User?            @relation("ModeratedArticles", fields: [moderatedBy], references: [id])
  user             User?            @relation("AuthorArticles", fields: [userId], references: [id])
  credits          ArticleCredit[]
  articleImages    ArticleImage[]

  @@index([userId])
  @@index([moderationStatus])
  @@index([isPublished])
}

model ArticleImage {
  id          String   @id @default(cuid())
  articleId   String
  url         String
  storagePath String
  createdAt   DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleCredit {
  id           String   @id @default(cuid())
  userId       String
  articleId    String
  articleTitle String
  month        Int
  year         Int
  creditedAt   DateTime @default(now())
  approvedAt   DateTime
  moderatedBy  String?
  article      Article  @relation(fields: [articleId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
  @@index([year, month])
}

model Document {
  id           String       @id @default(cuid())
  type         DocumentType
  url          String
  filename     String
  mimeType     String
  size         Int
  description  String?
  userId       String
  verifiedAt   DateTime?
  verifiedBy   String?
  uploadedAt   DateTime     @default(now())
  organization String?
  programName  String?
  year         Int?
  user         User         @relation("user_documents", fields: [userId], references: [id], onDelete: Cascade)
  verifier     User?        @relation("verifier_documents", fields: [verifiedBy], references: [id])

  @@index([userId])
  @@index([type])
  @@index([verifiedAt])
}

model Blocks {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  content     String?
  description String?
  isActive    Boolean @default(true)
}

model ModerationRecord {
  id          String           @id @default(cuid())
  status      ModerationStatus
  comment     String?
  userId      String
  moderatorId String?
  createdAt   DateTime         @default(now())
  moderator   User?            @relation("moderator_records", fields: [moderatorId], references: [id])
  user        User             @relation("moderated_user", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([moderatorId])
}

enum DialogStatus {
  ACTIVE // требует ответа модератора
  WAITING // ждем ответа пользователя
  ARCHIVED // закрыт/архив
}

model Dialog {
  id            String       @id @default(cuid())
  userId        String       @unique // один диалог на пользователя
  status        DialogStatus @default(ACTIVE)
  lastMessageAt DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  dialogId  String // связь с диалогом
  direction String // 'to_moder' или 'to_user'
  text      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  dialog Dialog @relation(fields: [dialogId], references: [id], onDelete: Cascade)

  @@index([dialogId])
  @@index([createdAt])
}

model Page {
  id              String   @id @default(cuid())
  slug            String   @unique
  adminTitle      String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  metaRobots      String?
  template        String
  content         String
  customHead      String?
  images          String[]
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model DataList {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String?
  items     Json     @db.Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

enum PsychologistStatus {
  PENDING
  CANDIDATE
  ACTIVE
  REJECTED
  BLOCKED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REVISION
  DRAFT
}

enum DocumentType {
  ACADEMIC_EDUCATION
  PROFESSIONAL_TRAINING
  COURSE
  SUPPORTING_DOC
  LINK
  PHOTO
  OTHER
}

enum NotificationType {
  LEAD // заявка от клиента
  ARTICLE_APPROVED // статья одобрена
  ARTICLE_REVISION // статья на доработку
  PROFILE_APPROVED // профиль одобрен
  PROFILE_REJECTED // профиль отклонен
  DOCUMENT_VERIFIED // документ проверен
  REMINDER // напоминание о статье
  INFO // новости проекта
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  linkUrl    String?
  linkText   String?
  isRead     Boolean          @default(false)
  isArchived Boolean          @default(false)
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  metadata   Json?            @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  deviceType String?  // 'desktop', 'mobile', 'tablet'
  deviceOs   String?  // 'windows', 'macos', 'ios', 'android', 'linux'
  browser    String?  // 'chrome', 'safari', 'firefox', 'edge', 'other'
  userAgent  String?  // исходный User-Agent
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
