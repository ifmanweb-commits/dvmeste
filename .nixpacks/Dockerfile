FROM ghcr.io/railwayapp/nixpacks:ubuntu-1745885067

ENTRYPOINT ["/bin/bash", "-l", "-c"]
WORKDIR /app/


COPY .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix
RUN nix-env -if .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix && nix-collect-garbage -d
RUN sudo apt-get update && sudo apt-get install -y --no-install-recommends curl wget

ARG CI COMPLAINT_RECEIVER_EMAIL COOLIFY_BRANCH COOLIFY_FQDN COOLIFY_RESOURCE_UUID COOLIFY_URL DATABASE_URL NIXPACKS_METADATA NIXPACKS_NODE_VERSION NODE_ENV NPM_CONFIG_PRODUCTION UNISENDER_API_KEY UNISENDER_CLASSIC_API_BASE UNISENDER_CLASSIC_LANG UNISENDER_COMPLAINT_LIST_ID UNISENDER_COMPLAINT_LIST_TITLE UNISENDER_FROM_EMAIL UNISENDER_FROM_NAME UNISENDER_MODE UNISENDER_PLATFORM
ENV CI=$CI COMPLAINT_RECEIVER_EMAIL=$COMPLAINT_RECEIVER_EMAIL COOLIFY_BRANCH=$COOLIFY_BRANCH COOLIFY_FQDN=$COOLIFY_FQDN COOLIFY_RESOURCE_UUID=$COOLIFY_RESOURCE_UUID COOLIFY_URL=$COOLIFY_URL DATABASE_URL=$DATABASE_URL NIXPACKS_METADATA=$NIXPACKS_METADATA NIXPACKS_NODE_VERSION=$NIXPACKS_NODE_VERSION NODE_ENV=$NODE_ENV NPM_CONFIG_PRODUCTION=$NPM_CONFIG_PRODUCTION UNISENDER_API_KEY=$UNISENDER_API_KEY UNISENDER_CLASSIC_API_BASE=$UNISENDER_CLASSIC_API_BASE UNISENDER_CLASSIC_LANG=$UNISENDER_CLASSIC_LANG UNISENDER_COMPLAINT_LIST_ID=$UNISENDER_COMPLAINT_LIST_ID UNISENDER_COMPLAINT_LIST_TITLE=$UNISENDER_COMPLAINT_LIST_TITLE UNISENDER_FROM_EMAIL=$UNISENDER_FROM_EMAIL UNISENDER_FROM_NAME=$UNISENDER_FROM_NAME UNISENDER_MODE=$UNISENDER_MODE UNISENDER_PLATFORM=$UNISENDER_PLATFORM

# setup phase
# noop

# install phase
ENV NIXPACKS_PATH=/app/node_modules/.bin:$NIXPACKS_PATH
COPY . /app/.
RUN --mount=type=cache,id=y8scwo8884cog4kwok4os0wc-/root/npm,target=/root/.npm npm ci

# build phase
COPY . /app/.
RUN --mount=type=cache,id=y8scwo8884cog4kwok4os0wc-next/cache,target=/app/.next/cache --mount=type=cache,id=y8scwo8884cog4kwok4os0wc-node_modules/cache,target=/app/node_modules/.cache npm run build


RUN printf '\nPATH=/app/node_modules/.bin:$PATH' >> /root/.profile


# start
COPY . /app

CMD ["npm run start"]

